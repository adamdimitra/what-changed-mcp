# GitHub Personal Access Token (required)
GITHUB_TOKEN=

# Optional: Comma-separated list of allowed repos (e.g., "owner/repo,org/*")
REPO_ALLOWLIST=

# Optional: Maximum retry attempts for rate-limited requests (default: 3)
MAX_RETRIES=

# Optional: Maximum bytes per file diff (default: 50000)
MAX_BYTES_PER_FILE=

# Optional: Logging level (default: INFO)
LOG_LEVEL=
